# MiMo / provider-side settings
# Replace these with the actual values from your TTS backend.
MIMO_API_KEY=your_mimo_api_key

# Telegram delivery settings
# Required if you want MiMo Voice to send Telegram voice messages.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Notes:
# - Current alpha code reads credentials from env or ~/.openclaw/.env.
# - Provider base_url / model are still code defaults today, but the long-term
#   direction is to move toward normalized provider config.
# - If you are reusing mini-vico config later, treat that as a config source,
#   not as a Telegram/plugin setting.
