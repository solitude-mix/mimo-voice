# MiMo / provider-side settings
# Replace these with the actual values from your TTS backend.
MIMO_PROVIDER_KIND=mimo
MIMO_PROVIDER_SOURCE=direct
MIMO_API_KEY=your_mimo_api_key
MIMO_API_URL=https://api.xiaomimimo.com/v1/chat/completions
MIMO_MODEL=mimo-v2-tts
MIMO_DEFAULT_VOICE=default_zh
MIMO_AUDIO_FORMAT=wav

# Planned/partial provider source adapter settings
# mini-vico source now supports a minimal JSON/YAML config adapter.
# Example:
# MIMO_PROVIDER_SOURCE=mini-vico
# MIMO_PROVIDER_PROFILE=default
# MINI_VICO_CONFIG_PATH=/path/to/mini-vico/config.json

# Telegram delivery settings
# Required if you want MiMo Voice to send Telegram voice messages.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_API_BASE=https://api.telegram.org

# Optional network proxy settings for Telegram / provider access.
# These are especially useful when the service runs under systemd --user,
# because systemd does not automatically inherit your interactive shell proxy.
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# ALL_PROXY=socks5://127.0.0.1:10808

# Notes:
# - Current alpha code reads these values from env or ~/.openclaw/.env.
# - Direct provider env vars work today.
# - mini-vico source is a planned config-source skeleton only for now.
